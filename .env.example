# Base URL for the PromptTokenizer API.
#
# Leave EMPTY in development to route /api and /health through the Vite dev
# proxy (configured in vite.config.ts to forward to http://localhost:8000).
#
# In production, set this to your deployed API origin, e.g.:
#   VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=
